# API keys for contact enrichment & SMTP verification
HUNTER_API_KEY=
HUNTER_IO_API_KEY=
PDL_API_KEY=
ZEROBOUNCE_API_KEY=

# Contact enrichment behavior
# auto = Hunter domain search, then PDL person search (waterfall)
CONTACT_ENRICHMENT_PROVIDER=auto
# When true, leads without a verified contact are excluded from the dataset
CONTACT_ENRICHMENT_DROP_IF_MISSING=false
# Minimum Hunter domain-search confidence before falling back to PDL
HUNTER_MIN_CONTACT_CONFIDENCE=70

# Email hygiene pipeline
# drop = exclude role inboxes (info@, sales@); review = keep in review bucket
EMAIL_ROLE_ACCOUNT_ACTION=drop
# Hunter score below this triggers ZeroBounce SMTP waterfall
EMAIL_HUNTER_MIN_SCORE=70

# CORS / deployment
ENVIRONMENT=development
API_BASE_URL=http://127.0.0.1:8000
FRONTEND_URL=https://lovable.app

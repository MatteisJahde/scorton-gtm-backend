# API keys for contact enrichment and email verification
ZEROBOUNCE_API_KEY=
HUNTER_API_KEY=
HUNTER_IO_API_KEY=
PDL_API_KEY=

# Contact enrichment behavior
# auto = Hunter domain search, then PDL person search
CONTACT_ENRICHMENT_PROVIDER=auto
# When true, leads without a verified contact are excluded from the dataset
CONTACT_ENRICHMENT_DROP_IF_MISSING=false

# CORS / deployment
ENVIRONMENT=development
API_BASE_URL=http://127.0.0.1:8000
FRONTEND_URL=https://lovable.app
